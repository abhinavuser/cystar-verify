PORT=5000
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/cystar
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_URL=http://localhost:3000

# Ed25519 keys for credential signing (base64 encoded PEM)
# leave blank on first run — server generates and logs them for you
SIGNING_KEY_PRIVATE=
SIGNING_KEY_PUBLIC=
